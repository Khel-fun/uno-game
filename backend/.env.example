# Backend Environment Configuration

# Server Configuration
PORT=4000
NODE_ENV=development

# Redis Configuration (optional - for game state persistence)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# CORS Configuration (optional)
# CORS_ORIGIN=http://localhost:3000

# Logging Configuration (optional)
# LOG_LEVEL=info

# Database / Tracking Configuration
# Set TRACKING_DB_ENABLED=true and provide POSTGRES_URL to enable DB writes.
# Without both, all tracking calls are no-ops and nothing is persisted.
# TRACKING_DB_ENABLED=true
# POSTGRES_URL=postgresql://user:password@host:5432/dbname
# TRACKING_DEFAULT_CHAIN_ID=84532

# Tracking queue tuning (optional)
# TRACKING_QUEUE_FLUSH_MS=2000
# TRACKING_QUEUE_BATCH_SIZE=50
